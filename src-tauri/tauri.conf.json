{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "scrobloop",
  "version": "0.1.0",
  "identifier": "com.julianrut.scrobloop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Scrobloop",
        "width": 360,
        "height": 480,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
"skipTaskbar": true
      }
    ],
"macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/recognize-audio"
    ]
  }
}
